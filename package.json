{
  "name": "gotcha",
  "version": "1.2",
  "description": "One-click bug report that ships with a runnable regression test.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "zip": "npm run build && rm -f gotcha-$npm_package_version.zip && cd dist && zip -r -X ../gotcha-$npm_package_version.zip . && cd ..",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "npm run build && playwright test"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.5.0",
    "@vitest/coverage-v8": "^4.1.8",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.1",
    "jsdom": "^27.0.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}
