    "@vitest/coverage-v8": "^4.1.8",
    "happy-dom": "^20.10.1",
    "jsdom": "^27.0.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}
