{
  "name": "gotcha",
  "version": "0.1.0",
  "description": "One-click bug report that ships with a runnable regression test.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "icons": "bash scripts/gen-icons.sh",
